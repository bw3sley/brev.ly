{
  "name": "server",
  "version": "1.0.0",
  "types": "module",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/infra/http/server.ts",
		"start": "node dist/server.js",
    "lint": "biome check --write ./src",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "dotenv -e .env -- tsx src/infra/db/seed.ts",
		"db:studio": "drizzle-kit studio",
    "db:migrate:test": "dotenv -e .env.test -- drizzle-kit migrate",
    "pretest": "pnpm run db:migrate:test",
    "pretest:watch": "pnpm run db:migrate:test",
    "build": "tsup-node"
  },
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "@aws-sdk/lib-storage": "^3.1072.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "csv-stringify": "^6.8.0",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.9",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@faker-js/faker": "^10.5.0",
    "@types/node": "^26.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
